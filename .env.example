# 前端公开环境变量。这里只写变量名，不写真实 Key。
VITE_APP_ENV=development
VITE_APP_VERSION=
VITE_COMMIT_SHA=
VITE_BUILD_TIME=
VITE_DEPLOY_PLATFORM=
VITE_RELEASE_NOTES=

# 数据源模式。留空时：有 Supabase 配置自动走 supabase；无 Supabase 配置进入本地演示。
VITE_DATA_MODE=
VITE_API_BASE_URL=
VITE_PUBLIC_APP_ORIGIN=https://wall.hc12345.com
# 禁止在生产环境启用任何前端免登录或本地演示绕过。
VITE_FORCE_LOCAL_DEMO=false

# Supabase 正式数据源
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 高德地图 Web JS API
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_CODE=

# Kimi 图片分类。不要把真实服务端密钥暴露到前端，正式使用建议走后端代理。
VITE_KIMI_API_KEY=
VITE_KIMI_CLASSIFY_ENDPOINT=

# Node / Express 服务端配置，仅云服务器或本地 Express 模式需要。
PORT=8787
PUBLIC_APP_ORIGIN=https://wall.hc12345.com
APP_ORIGIN=https://wall.hc12345.com
CORS_ORIGIN=https://wall.hc12345.com
SESSION_SECRET=
JWT_SECRET=
INIT_ADMIN_USERNAME=
INIT_ADMIN_PHONE=
INIT_ADMIN_PASSWORD=

# Vercel Serverless API 如需继续使用服务端代理，需要配置以下服务端变量。
# 不要在前端代码中读取或打印 service role。
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
