# 前端公开环境变量。这里只写变量名，不写真实 Key。
VITE_APP_ENV=development
VITE_APP_VERSION=
VITE_COMMIT_SHA=
VITE_BUILD_TIME=
VITE_DEPLOY_PLATFORM=
VITE_RELEASE_NOTES=

# 当前项目运行模式
VITE_DATA_MODE=mock-server
VITE_API_BASE_URL=
VITE_PUBLIC_APP_ORIGIN=

# 高德地图 Web JS API
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_CODE=

# Supabase 历史/可选配置。当前主线不强依赖。
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Kimi 图片分类。不要把真实服务端密钥暴露到前端，正式使用建议走后端代理。
VITE_KIMI_API_KEY=
VITE_KIMI_CLASSIFY_ENDPOINT=

# Node / Express 服务端配置
PORT=8787
PUBLIC_APP_ORIGIN=
